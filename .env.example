# 복사 후 .env 로 저장:  copy .env.example .env
# MAS_ 접두사 환경 변수

# OpenAI API 키 (LLM 사용 시 필수 — 이름은 반드시 OPENAI_API_KEY)
# OPENAI_API_KEY=sk-...

# REST 대시보드 바인딩 호스트 (기본 127.0.0.1 — 외부 접근 허용 시 0.0.0.0)
# MAS_API_HOST=127.0.0.1

# REST 대시보드 포트 (기본 8787)
# MAS_API_PORT=8787

# 공장 환경 사이클 간격(초) — main.py FactoryRuntime 택트
# MAS_TAKT_SEC=2.0

# PlanningAgent LLM 모델명 (오케스트레이션·근거 서술)
# MAS_LLM_MODEL=gpt-4o-mini

# 도메인 전용 소형 모델명 (선택, 불량/RUL 등 추후 전용 호출 분기용 메타)
# MAS_LLM_DOMAIN_MODEL=

# 로깅: DEBUG, INFO, WARNING, ERROR
# MAS_LOG_LEVEL=INFO

# API 보호(비어 있으면 비활성). 설정 시 /api/* 에 Authorization: Bearer <값> 또는 ?token=
# MAS_API_BEARER_TOKEN=

# 라우터 LLM 범위: pa_only(기본, PA만 복합경보 분석) | all_gated(비PA도 게이트 가능)
# MAS_LLM_ROUTER_SCOPE=pa_only
# all_gated 일 때만 의미 있음: 비 PA 에이전트도 고심각·복합 경보 시 LLM 상황분석 후보
# MAS_LLM_PER_AGENT_ASSIST=0

# CORS — 쉼표 구분 Origin 또는 *
# MAS_CORS_ORIGINS=*

# SRA 에이전트 프로토콜: LangGraph 그래프 사용(1, 기본) / 순차 폴백(0)
# MAS_USE_LANGGRAPH=1
