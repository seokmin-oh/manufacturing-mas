# Copy to .env and edit values as needed.

# OpenAI API key
# OPENAI_API_KEY=sk-...

# API host/port
# MAS_API_HOST=127.0.0.1
# MAS_API_PORT=8787

# Factory takt time in seconds
# MAS_TAKT_SEC=2.0

# LLM configuration
# MAS_LLM_MODEL=gpt-4o-mini
# MAS_LLM_DOMAIN_MODEL=
# MAS_LOG_LEVEL=INFO
# MAS_API_BEARER_TOKEN=
# MAS_LLM_ROUTER_SCOPE=pa_only
# MAS_LLM_PER_AGENT_ASSIST=0
# MAS_CORS_ORIGINS=*
# MAS_RUNTIME_MODE=hybrid
# MAS_CONNECTOR_POLL_SEC=5.0
# MAS_EVENT_DISPATCH_SEC=0.5

# Connector mode: off | sample | file | rest
# MAS_CONNECTOR_MODE=sample

# File-based connector inputs
# MAS_MES_FILE_PATH=
# MAS_ERP_FILE_PATH=
# MAS_QMS_FILE_PATH=

# REST-based connector base URLs
# MAS_MES_BASE_URL=
# MAS_ERP_BASE_URL=
# MAS_QMS_BASE_URL=

# LangGraph agent protocol toggle
# MAS_USE_LANGGRAPH=1
